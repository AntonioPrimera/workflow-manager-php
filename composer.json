{
    "name": "antonioprimera/workflow-manager-php",
    "description": "Workflow Manager php integration package",
    "keywords": [
        "AntonioPrimera",
        "workflow-manager-php"
    ],
    "homepage": "https://github.com/antonioprimera/workflow-manager-php",
    "license": "MIT",
    "authors": [
        {
            "name": "Antonio Primera",
            "email": "antonio@cus.ro",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0",
        "illuminate/filesystem": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.0",
        "spatie/ray": "^1.28",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "AntonioPrimera\\WorkflowManager\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AntonioPrimera\\WorkflowManager\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
            "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "AntonioPrimera\\WorkflowManager\\WorkflowManagerInstallerServiceProvider"
            ]
        }
    }
}
